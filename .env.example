# BTNG Platform Environment Configuration

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Platform Identity
BTNG_VERSION=0.1.0
BTNG_ENVIRONMENT=launch-phase

# Trust Union Protocol
TRUST_UNION_ENABLED=true
TRUST_UNION_NETWORK=development

# Gold Card Service
GOLDCARD_ISSUER=BTNG-SOVEREIGN
GOLDCARD_VERIFICATION_LEVEL=basic

# Wallet Service
WALLET_CURRENCY=BTNG
WALLET_NETWORK=testnet

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30000

# ============================================================================
# BLOCKCHAIN DEPLOYMENT CONFIGURATION (Required for Sepolia deployment)
# ============================================================================

# RPC Provider API Key (get from https://infura.io or https://alchemy.com)
INFURA_API_KEY=your_infura_api_key_here

# Ethereum Wallet Private Key (get from MetaMask - NEVER share this!)
PRIVATE_KEY=your_private_key_without_0x_prefix

# Optional: Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Network Configuration
NETWORK=sepolia
CHAIN_ID=11155111

# ============================================================================
# SECURITY NOTES:
# - Never commit real values to version control
# - Use environment-specific .env files (.env.local, .env.production)
# - Consider using secret management tools for production
# ============================================================================

# Future: Database Configuration
# DATABASE_URL=
# DATABASE_POOL_SIZE=

# Future: Redis Cache
# REDIS_URL=
# REDIS_TTL=

# Future: External Services
# MOBILE_MONEY_API_KEY=
# COUNTRY_VERIFICATION_API=
