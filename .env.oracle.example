# BTNG Oracle Updater Environment Template
# Copy to a secure runtime environment (do NOT commit private keys)

# Required
BTNG_ORACLE_RPC_URL=https://ethereum-sepolia.publicnode.com
BTNG_ORACLE_ADDRESS=0xYourDeployedOracleAddress
BTNG_ORACLE_ADMIN_PRIVATE_KEY=0xYourPrivateKey

# Optional
BTNG_GOLD_PRICE_API_URL=http://localhost:64799/api/btng/gold/price/latest
BTNG_ORACLE_PRICE_FIELD=base_price_gram
BTNG_ORACLE_PUSH_INTERVAL_MS=60000
