# BTNG Watchtower + Merchant Deployment Configuration
# Format: Name|Endpoint|Country|Weight,Name|Endpoint|Country|Weight
BTNG_WATCHTOWER_NODES=Ghana Parent|http://74.118.126.72:64799|Ghana|10,Nigeria Node|http://NIGERIA_NODE_IP:64799|Nigeria|6,Kenya Node|http://KENYA_NODE_IP:64799|Kenya|6

# Base chain height for startup fallback
BTNG_GENESIS_LEDGER_HEIGHT=12459

# Watchtower cryptographic verification/signing (ES256)
# Prefer file paths for key material in production
BTNG_ES256_PUBLIC_KEY_PATH=./btng-es256-public-key.pem
BTNG_ES256_PRIVATE_KEY_PATH=./btng-es256-private-key.pem

# Optional inline PEM support (use \n for line breaks)
# BTNG_ES256_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# BTNG_ES256_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Replay protection window for signed node registrations
BTNG_WATCHTOWER_MAX_TIMESTAMP_SKEW_SECONDS=300

# Merchant deployment package values
BTNG_MERCHANT_ANDROID_APK_URL=https://download.btng.global/merchant/android/latest.apk
BTNG_MERCHANT_WEB_URL=https://merchant.btng.global
BTNG_MERCHANT_PACKAGE_CHECKSUM=pending-signature
BTNG_MERCHANT_INSTALL_GUIDE_URL=https://docs.btng.global/merchant-install
