{
  "dashboard": {
    "id": null,
    "title": "BTNG Sovereign Platform",
    "tags": ["btng", "sovereign", "blockchain"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "BTNG SDK Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(btng_sdk_request_duration_seconds_sum[5m]) / rate(btng_sdk_request_duration_seconds_count[5m])",
            "legendFormat": "Average Response Time"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "UTXO Pool Size",
        "type": "graph",
        "targets": [
          {
            "expr": "btng_sdk_utxo_pool_size",
            "legendFormat": "UTXO Count"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Frontend Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(btng_frontend_request_duration_seconds_sum[5m]) / rate(btng_frontend_request_duration_seconds_count[5m])",
            "legendFormat": "Frontend Response Time"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(btng_sdk_requests_total{status=~\"5..\"}[5m]) / rate(btng_sdk_requests_total[5m]) * 100",
            "legendFormat": "SDK Error Rate %"
          },
          {
            "expr": "rate(btng_frontend_requests_total{status=~\"5..\"}[5m]) / rate(btng_frontend_requests_total[5m]) * 100",
            "legendFormat": "Frontend Error Rate %"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "5s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}